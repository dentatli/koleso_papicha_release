{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["items"],
  "properties": {
    "items": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "category",
          "mentionedTitle",
          "displayTitle",
          "searchQueries",
          "originalLanguage",
          "confidence",
          "reason"
        ],
        "properties": {
          "category": {
            "type": "string",
            "enum": ["game", "anime", "movie", "tv_show", "cartoon", "other", "unknown"]
          },
          "mentionedTitle": { "type": "string", "minLength": 1, "maxLength": 200 },
          "displayTitle": { "type": "string", "minLength": 1, "maxLength": 200 },
          "searchQueries": {
            "type": "array",
            "minItems": 1,
            "maxItems": 4,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1, "maxLength": 200 }
          },
          "originalLanguage": {
            "type": "string",
            "enum": ["ru", "en", "ja", "ko", "zh", "other", "unknown"]
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "reason": { "type": "string", "minLength": 1, "maxLength": 500 }
        }
      }
    }
  }
}
